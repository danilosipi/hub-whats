# =========================================
# PORTA
PORT=3001

# =========================================
# HUB PUBLIC URL
# =========================================
PUBLIC_HUB_BASE_URL=https://api.dstudium.com
 
# =========================================
# Evolution-API Whats
EVOLUTION_DEFAULT_ACCOUNT_ID=
EVOLUTION_DEDUPE_WINDOW_MS=300000

# =========================================
# META APP
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=https://api.dstudium.com/oauth/meta/callback

# =========================================
# TOKEN DE ENVIO (OBRIGATÓRIO AGORA)
META_ACCESS_TOKEN=

# =========================================
# WEBHOOK
# Token de verificação do webhook (WhatsApp Cloud API / Meta).
# Deve ser o mesmo valor configurado no painel da Meta ao registrar a URL de callback.
META_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_META_VERIFY_TOKEN=
 
# =========================================
# MULTI-TENANT (ATUALIZADO COM SEU NOVO NÚMERO)
# Multi-tenant: mapeamento phone_number_id (Cloud API) / número exibido → account_id do Minha Agenda.
WHATSAPP_INTEGRATIONS_JSON=
WHATSAPP_INTEGRATIONS_DYNAMIC_PATH=/data/whatsapp-integrations.dynamic.json
PROCESSOR_ACCOUNT_ID=
 
# =========================================
# GRAPH API
META_GRAPH_API_VERSION=v19.0
META_OAUTH_SCOPES=whatsapp_business_management,business_management
 
# =========================================
# BACKEND PRINCIPAL (MAZ)
# URL base do backend principal (Minha Agenda) que recebe eventos normalizados.
PROCESSOR_API_URL=http://172.17.0.1:3003

# =========================================
# INTEGRAÇÃO COM MAZ (PODE MANTER)
PROCESSOR_INTEGRATION_UPSERT_URL=https://api.minhaagendazap.com/internal/integrations/upsert
PROCESSOR_INTEGRATION_UPSERT_SECRET=
