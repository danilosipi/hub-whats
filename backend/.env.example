# URL base do backend principal (Minha Agenda) que recebe eventos normalizados.
# POST: {PROCESSOR_API_URL}/whatsapp/webhook
PROCESSOR_API_URL=http://localhost:3000

# Multi-tenant: mapeamento phone_number_id (Cloud API) / número exibido → account_id do Minha Agenda.
# Ex.: [{"phone_number_id":"123456789","account_id":"uuid-da-conta","display_phone_number":"5511999999999"}]
WHATSAPP_INTEGRATIONS_JSON=

# Ficheiro JSON (gravável) onde o callback OAuth guarda o mapeamento após conexão — sobrevive a restarts.
# Ex. (Docker): /data/whatsapp-integrations.dynamic.json
WHATSAPP_INTEGRATIONS_DYNAMIC_PATH=

# Opcional (legado, single-tenant): usado só se não houver match em WHATSAPP_INTEGRATIONS_JSON.
# Para Evolution (fase inicial), pode ser usado como account_id default.
# PROCESSOR_ACCOUNT_ID=dev-account

# Opcional: fallback preferencial para webhooks da Evolution quando não houver match por instance/phone.
# EVOLUTION_DEFAULT_ACCOUNT_ID=dev-account

# Janela de deduplicação em memória por messageId (ms).
# EVOLUTION_DEDUPE_WINDOW_MS=300000

# Token de verificação do webhook (WhatsApp Cloud API / Meta).
# Deve ser o mesmo valor configurado no painel da Meta ao registrar a URL de callback.
META_WEBHOOK_VERIFY_TOKEN=dstudium_token

# OAuth / Embedded Signup (troca de code por access token na Graph API).
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=https://api.dstudium.com/oauth/meta/callback

# Segredo HMAC para assinar o parâmetro state (recomendado). Se vazio, usa META_APP_SECRET.
# META_OAUTH_STATE_SECRET=
# META_OAUTH_STATE_TTL_SEC=3600

# Versão da Graph API (token OAuth, /me, WABA).
# META_GRAPH_API_VERSION=v19.0

# Scopes do diálogo OAuth (GET /oauth/meta/authorize).
# META_OAUTH_SCOPES=whatsapp_business_management,business_management

# URL pública deste hub para montar webhook_url na metadata enviada ao processador.
# PUBLIC_HUB_BASE_URL=https://api.dstudium.com

# Minha Agenda: URL para upsert da integração (card CONNECTED, token, metadata). Opcional mas recomendado.
# PROCESSOR_INTEGRATION_UPSERT_URL=http://localhost:3000/internal/hub/integrations/whatsapp-meta
# PROCESSOR_INTEGRATION_UPSERT_SECRET=

# Redirecionamento pós-sucesso: URL base do frontend para return_url relativa, ou origens absolutas permitidas.
# FRONTEND_APP_BASE_URL=https://app.dominio.com
# META_OAUTH_ALLOWED_RETURN_ORIGINS=https://app.dominio.com,https://localhost:5173

# Porta HTTP (opcional; padrão 3001)
# PORT=3001
